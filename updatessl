    def detect_usb_forensics(self):
        """USB forensic dumps detection"""
        for partition in psutil.disk_partitions():
            if 'removable' in partition.opts.lower():
                usb_path = partition.mountpoint
                for ext in self.forensic_extensions:
                    pattern = os.path.join(usb_path, f"*{ext}")
                    if any(Path(usb_path).glob(f"*{ext}")):
                        self.detected_tools.append(f"USB dump {ext}")
                        return True
